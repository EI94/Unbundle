{
  "name": "unbundle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "vercel:link": "vercel link --yes",
    "vercel:pull": "vercel env pull .env.vercel --yes",
    "vercel:pull:production": "vercel env pull .env.vercel.production --environment production --yes",
    "vercel:env:sync": "node scripts/sync-vercel-env.mjs",
    "vercel:deploy": "vercel --prod",
    "vercel:deploy:preview": "vercel"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/react": "^3.0.158",
    "@base-ui/react": "^1.3.0",
    "@neondatabase/serverless": "^1.0.2",
    "@types/d3": "^7.4.3",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.3.3",
    "ai": "^6.0.156",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^50.0.0"
  }
}
